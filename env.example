# ================================
# Environment Variables for aderabiruk.dev
# ================================
# Copy this file to .env.local and fill in your values

# --------------------------------
# Email Configuration (Resend)
# --------------------------------
# Get your API key from: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxx

# Email address to receive contact form submissions
CONTACT_TO_EMAIL=your-email@example.com

# --------------------------------
# Calendar Booking
# --------------------------------
# URL to your calendar booking page (e.g., Calendly, Cal.com)
# This enables "Book a Call" option for Hiring/Contract and Collaboration inquiries
# If not set, the booking option will be hidden
CALENDAR_BOOKING_URL=https://calendly.com/your-username

# Make this available to the client
NEXT_PUBLIC_CALENDAR_BOOKING_URL=https://calendly.com/your-username

# --------------------------------
# AI Chat (OpenAI)
# --------------------------------
# Optional: Enables AI-powered chat responses
# If not set, the chatbot will use a deterministic keyword-based fallback
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxx
